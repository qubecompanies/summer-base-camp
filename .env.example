# Firebase web app config (Project settings -> Your apps -> SDK setup -> Config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App config
VITE_FAMILY_ID=eaker

# PINs — light family gates (NOT real security; they ship in the client bundle).
# Leave blank to use the in-code defaults noted in each comment.
VITE_PARENT_PIN=        # default 1234
VITE_PIN_EVERETT=       # default 1111
VITE_PIN_PARKER=        # default 2222
