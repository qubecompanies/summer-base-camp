rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Images only, capped at ~8MB, signed-in users only. Locked to the one
    // known family folder so a client can't write under another family's path.
    function okImage() {
      return request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Proof photos for claimed quests.
    match /proofs/eaker/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if okImage();
    }

    // Per-player photo avatars (parent-set).
    match /avatars/eaker/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if okImage();
    }
  }
}
