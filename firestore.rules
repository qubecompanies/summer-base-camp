// Additive multi-tenant rules (transition). Keeps `families/eaker` open so the
// live single-family app still works; ADDS accounts, member-scoped families,
// invite-only creation, and co-parent self-join. The eaker block is removed at
// the end of cutover (see firestore.rules.cutover).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userEmail() {
      return signedIn() && request.auth.token.email is string ? request.auth.token.email.lower() : '';
    }
    function isAdminEmail() { return userEmail() == 'philipeaker@gmail.com'; }
    function isMember(fid) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/families/$(fid)).data.members;
    }
    function hasInvite() {
      return userEmail() != '' && exists(/databases/$(database)/documents/invites/$(userEmail()));
    }
    function inviteFamily() {
      return get(/databases/$(database)/documents/invites/$(userEmail())).data.familyId;
    }

    // Per-user account -> familyId mapping. Each user sees only their own.
    match /accounts/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Invite-only gate. A user can read their own invite; admins can list/manage
    // new-family invites; a family member can invite a co-parent to THEIR family.
    match /invites/{email} {
      allow get: if signedIn();
      allow list: if isAdminEmail();
      allow create, update: if isAdminEmail()
        || (signedIn() && request.resource.data.familyId is string && isMember(request.resource.data.familyId));
      allow delete: if isAdminEmail()
        || (signedIn() && resource.data.familyId is string && isMember(resource.data.familyId));
    }

    // LEGACY single-family tree — kept open during the transition. Removed in cutover.
    match /families/eaker {
      allow read, write: if signedIn();
      match /{document=**} { allow read, write: if signedIn(); }
    }

    // Multi-tenant families.
    match /families/{familyId} {
      allow read, write: if isMember(familyId);
      // Create requires owner stamp + an invite (or admin).
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && (request.auth.uid in request.resource.data.members)
        && (isAdminEmail() || hasInvite());
      // Co-parent self-join: an invited (to THIS family) non-member may add only
      // themselves to the members map.
      allow update: if isMember(familyId)
        || (
          signedIn()
          && hasInvite()
          && inviteFamily() == familyId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt'])
          && request.resource.data.members[request.auth.uid] != null
          && !(request.auth.uid in resource.data.members)
        );
      match /{document=**} {
        allow read, write: if isMember(familyId);
      }
    }
  }
}
